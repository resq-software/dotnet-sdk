{
  "branches": ["main"],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/changelog",
      {
        "changelogFile": "CHANGELOG.md"
      }
    ],
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "sed -i 's|<Version>.*</Version>|<Version>${nextRelease.version}</Version>|' Directory.Build.props && dotnet build --configuration Release && dotnet pack --configuration Release /p:PackageVersion=${nextRelease.version} --output ./nupkgs",
        "publishCmd": "dotnet nuget push ./nupkgs/*.nupkg --api-key \"$NUGET_API_KEY\" --source https://api.nuget.org/v3/index.json --skip-duplicate"
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": ["Directory.Build.props", "CHANGELOG.md"],
        "message": "chore(release): ${nextRelease.version}"
      }
    ],
    "@semantic-release/github"
  ]
}
